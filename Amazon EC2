Node.js
const {
S3Client,
PutObjectCommand
}=require("@aws-sdk/client-s3");

const fs=require("fs");

const client=new S3Client({region:"us-east-1"});

async function upload(){

await client.send(

new PutObjectCommand({

Bucket:"company-backup",

Key:"website.zip",

Body:fs.readFileSync("website.zip")

}));

}

upload();
